---
interface FeatureItem {
  icon: string;
  title: string;
  description: string;
}

interface Props {
  t: {
    features: {
      title: string;
      items: FeatureItem[];
    };
  };
}

const { t } = Astro.props;
---

<section id="features" class="py-20 px-4">
  <div class="max-w-6xl mx-auto">
    <h2 class="text-3xl md:text-4xl font-bold text-center mb-12">
      <span class="gradient-text">{t.features.title}</span>
    </h2>

    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
      {t.features.items.map((item, index) => (
        <div class={`card card-hover animate-fade-in-up animate-delay-${(index + 1) * 100}`}>
          <div class="w-12 h-12 rounded-lg bg-gradient-to-br from-accent-orange/20 to-accent-red/20 flex items-center justify-center mb-4">
            <ion-icon name={item.icon} class="text-2xl text-accent-orange"></ion-icon>
          </div>
          <h3 class="text-xl font-semibold mb-2 text-text-primary">{item.title}</h3>
          <p class="text-text-secondary">{item.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
