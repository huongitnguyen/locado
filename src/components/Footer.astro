---
interface Props {
  t: {
    footer: {
      madeBy: string;
      by: string;
      author: string;
      links: {
        github: string;
        website: string;
      };
    };
  };
}

const { t } = Astro.props;
---

<footer class="py-12 px-4 border-t border-white/10">
  <div class="max-w-6xl mx-auto">
    <div class="flex flex-col md:flex-row items-center justify-between gap-6">
      <!-- Logo & Author -->
      <div class="flex items-center gap-4">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 64 64" width="24" height="24">
          <defs>
            <linearGradient id="footerLogoGradient" x1="0%" y1="0%" x2="100%" y2="100%">
              <stop offset="0%" stop-color="#f97316"/>
              <stop offset="100%" stop-color="#dc2626"/>
            </linearGradient>
          </defs>
          <g fill="none" stroke="url(#footerLogoGradient)" stroke-width="4" stroke-linecap="round" stroke-linejoin="round">
            <path d="M18 28 C14 32 14 38 18 42 L22 46 C26 50 32 50 36 46"/>
            <path d="M46 36 C50 32 50 26 46 22 L42 18 C38 14 32 14 28 18"/>
            <line x1="26" y1="38" x2="38" y2="26"/>
          </g>
        </svg>
        <span class="text-text-secondary">
          {t.footer.madeBy} <ion-icon name="heart" class="text-red-500 align-middle"></ion-icon> {t.footer.by}
          <a href="https://hxd.app" target="_blank" rel="noopener noreferrer" class="text-text-primary hover:text-accent-orange transition-colors">
            {t.footer.author}
          </a>
        </span>
      </div>

      <!-- Links -->
      <div class="flex items-center gap-6">
        <a
          href="https://github.com/hxd-labs/locado"
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center gap-2 text-text-secondary hover:text-text-primary transition-colors"
        >
          <ion-icon name="logo-github" class="text-xl"></ion-icon>
          {t.footer.links.github}
        </a>
        <a
          href="https://hxd.app"
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center gap-2 text-text-secondary hover:text-text-primary transition-colors"
        >
          <ion-icon name="globe-outline" class="text-xl"></ion-icon>
          {t.footer.links.website}
        </a>
      </div>
    </div>

    <!-- Copyright -->
    <div class="mt-8 pt-8 border-t border-white/10 text-center text-text-secondary text-sm">
      <p>&copy; {new Date().getFullYear()} Locado. All rights reserved.</p>
    </div>
  </div>
</footer>
