---
interface Props {
  t: {
    footer: {
      madeBy: string;
      by: string;
      author: string;
      links: {
        github: string;
        website: string;
      };
    };
  };
}

const { t } = Astro.props;
---

<footer class="py-12 px-4" style="border-top: 1px solid var(--border-color);">
  <div class="max-w-6xl mx-auto">
    <div class="flex flex-col md:flex-row items-center justify-between gap-6">
      <!-- Logo & Author -->
      <div class="flex items-center gap-4">
        <img src="/logo.svg" alt="Locado Logo" class="mx-auto relative" width="24" height="24">
        <span class="text-xl font-bold gradient-text">LOCADO</span>
        <span class="text-text-secondary">
          {t.footer.madeBy} <ion-icon name="heart" class="text-red-500 align-middle"></ion-icon> {t.footer.by}
          <a href="https://hxd.vn" target="_blank" rel="noopener noreferrer" class="text-text-primary hover:text-accent-orange transition-colors">
            {t.footer.author}
          </a>
        </span>
      </div>

      <!-- Links -->
      <div class="flex items-center gap-6">
        <a
          href="https://github.com/xuandung38/locado"
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center gap-2 text-text-secondary hover:text-text-primary transition-colors"
        >
          <ion-icon name="logo-github" class="text-xl"></ion-icon>
          {t.footer.links.github}
        </a>
        <a
          href="https://locado.hxd.app"
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center gap-2 text-text-secondary hover:text-text-primary transition-colors"
        >
          <ion-icon name="globe-outline" class="text-xl"></ion-icon>
          {t.footer.links.website}
        </a>
      </div>
    </div>

    <!-- Copyright -->
    <div class="mt-8 pt-8 text-center text-text-secondary text-sm" style="border-top: 1px solid var(--border-color);">
      <p>&copy; {new Date().getFullYear()} Locado. All rights reserved.</p>
    </div>
  </div>
</footer>
