---
interface Props {
  t: {
    sponsor: {
      title: string;
      description: string;
      button: string;
    };
  };
}

const { t } = Astro.props;
---

<section id="sponsor" class="py-20 px-4">
  <div class="max-w-4xl mx-auto">
    <div class="card text-center animate-fade-in-up">
      <div class="flex justify-center mb-4">
        <ion-icon name="heart" class="text-4xl text-accent-red"></ion-icon>
      </div>
      <h2 class="text-2xl md:text-3xl font-bold mb-4">
        <span class="gradient-text">{t.sponsor.title}</span>
      </h2>
      <p class="text-text-secondary text-lg mb-6 max-w-2xl mx-auto">
        {t.sponsor.description}
      </p>
      <a
        href="https://github.com/sponsors/xuandung38"
        target="_blank"
        rel="noopener noreferrer"
        class="btn-primary inline-flex items-center gap-2"
      >
        <ion-icon name="logo-github" class="text-xl"></ion-icon>
        {t.sponsor.button}
      </a>
    </div>
  </div>
</section>
