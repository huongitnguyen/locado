---
// Screenshots section - shows dashboard preview
---

<section class="py-20 px-4 bg-bg-secondary/50">
  <div class="max-w-5xl mx-auto">
    <div class="relative rounded-xl overflow-hidden border border-white/10 shadow-2xl shadow-accent-orange/10">
      <!-- Browser chrome mockup -->
      <div class="bg-bg-secondary px-4 py-3 flex items-center gap-2 border-b border-white/10">
        <div class="flex gap-1.5">
          <div class="w-3 h-3 rounded-full bg-red-500/80"></div>
          <div class="w-3 h-3 rounded-full bg-yellow-500/80"></div>
          <div class="w-3 h-3 rounded-full bg-green-500/80"></div>
        </div>
        <div class="flex-1 text-center">
          <span class="text-xs text-text-secondary bg-bg-primary px-3 py-1 rounded">localhost:2280</span>
        </div>
      </div>

      <!-- Dashboard screenshot -->
      <img
        src="/screenshots/dashboard.png"
        alt="Locado Dashboard - Manage your local development domains"
        class="w-full"
        onerror="this.parentElement.innerHTML='<div class=\\'bg-bg-primary p-8 min-h-[300px] flex items-center justify-center\\'><div class=\\'text-center text-text-secondary\\'><ion-icon name=\\'desktop-outline\\' class=\\'text-6xl mb-4 opacity-50\\'></ion-icon><p class=\\'text-lg\\'>Dashboard Preview</p><p class=\\'text-sm opacity-70\\'>Add screenshot to /public/screenshots/dashboard.png</p></div></div>'"
      />
    </div>
  </div>
</section>
