---
interface Props {
  t: {
    hero: {
      title: string;
      typingTexts: string[];
      installBtn: string;
      docsBtn: string;
    };
  };
}

const { t } = Astro.props;
---

<section class="min-h-screen flex items-center justify-center pt-16 px-4 section-gradient relative">
  <!-- Additional decorative orb for hero -->
  <div class="absolute top-1/4 left-1/2 -translate-x-1/2 w-[600px] h-[600px] rounded-full blur-[120px] opacity-30 bg-gradient-to-r from-accent-orange/40 to-accent-red/30 -z-10"></div>
  
  <div class="max-w-4xl mx-auto text-center relative z-10">
    <!-- Logo Icon with glow -->
    <div class="mb-10 animate-fade-in-up relative">
      <div class="absolute inset-0 blur-2xl bg-gradient-to-r from-accent-orange/30 to-accent-red/30 rounded-full scale-150"></div>
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 64 64" width="100" height="100" class="mx-auto relative">
        <defs>
          <linearGradient id="heroLogoGradient" x1="0%" y1="0%" x2="100%" y2="100%">
            <stop offset="0%" stop-color="#f97316"/>
            <stop offset="100%" stop-color="#dc2626"/>
          </linearGradient>
          <filter id="glow">
            <feGaussianBlur stdDeviation="2" result="coloredBlur"/>
            <feMerge>
              <feMergeNode in="coloredBlur"/>
              <feMergeNode in="SourceGraphic"/>
            </feMerge>
          </filter>
        </defs>
        <g fill="none" stroke="url(#heroLogoGradient)" stroke-width="3.5" stroke-linecap="round" stroke-linejoin="round" filter="url(#glow)">
          <path d="M18 28 C14 32 14 38 18 42 L22 46 C26 50 32 50 36 46"/>
          <path d="M46 36 C50 32 50 26 46 22 L42 18 C38 14 32 14 28 18"/>
          <line x1="26" y1="38" x2="38" y2="26"/>
        </g>
      </svg>
    </div>

    <!-- Title -->
    <h1 class="text-5xl md:text-7xl font-bold mb-8 animate-fade-in-up animate-delay-100">
      <span class="gradient-text">{t.hero.title}</span>
    </h1>

    <!-- Typing Animation -->
    <div class="h-10 mb-12 animate-fade-in-up animate-delay-200">
      <p id="typingText" class="text-xl md:text-2xl text-text-secondary typing-text"></p>
    </div>

    <!-- CTA Buttons -->
    <div class="flex flex-col sm:flex-row items-center justify-center gap-5 animate-fade-in-up animate-delay-300">
      <a href="#install" class="btn-primary text-lg">
        <ion-icon name="download-outline"></ion-icon>
        {t.hero.installBtn}
      </a>
      <a href="https://github.com/hxd-labs/locado#readme" target="_blank" rel="noopener noreferrer" class="btn-secondary text-lg">
        <ion-icon name="book-outline"></ion-icon>
        {t.hero.docsBtn}
      </a>
    </div>
  </div>

  <!-- Scroll indicator - moved outside max-w container for proper centering -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce">
    <ion-icon name="chevron-down-outline" class="text-3xl text-text-secondary opacity-60"></ion-icon>
  </div>
</section>

<script define:vars={{ typingTexts: t.hero.typingTexts }}>
  const texts = typingTexts;
  const el = document.getElementById('typingText');
  let textIndex = 0;
  let charIndex = 0;
  let isDeleting = false;

  function type() {
    if (!el) return;

    const currentText = texts[textIndex];

    if (isDeleting) {
      el.textContent = currentText.substring(0, charIndex - 1);
      charIndex--;
    } else {
      el.textContent = currentText.substring(0, charIndex + 1);
      charIndex++;
    }

    let delay = isDeleting ? 30 : 50;

    if (!isDeleting && charIndex === currentText.length) {
      delay = 2000;
      isDeleting = true;
    } else if (isDeleting && charIndex === 0) {
      isDeleting = false;
      textIndex = (textIndex + 1) % texts.length;
      delay = 500;
    }

    setTimeout(type, delay);
  }

  type();
</script>
