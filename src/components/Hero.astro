---
interface Props {
  t: {
    hero: {
      title: string;
      typingTexts: string[];
      installBtn: string;
      docsBtn: string;
    };
  };
}

const { t } = Astro.props;
---

<section class="min-h-screen flex items-center justify-center pt-16 px-4">
  <div class="max-w-4xl mx-auto text-center">
    <!-- Logo Icon -->
    <div class="mb-8 animate-fade-in-up">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 64 64" width="80" height="80" class="mx-auto">
        <defs>
          <linearGradient id="heroLogoGradient" x1="0%" y1="0%" x2="100%" y2="100%">
            <stop offset="0%" stop-color="#f97316"/>
            <stop offset="100%" stop-color="#dc2626"/>
          </linearGradient>
        </defs>
        <g fill="none" stroke="url(#heroLogoGradient)" stroke-width="3.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M18 28 C14 32 14 38 18 42 L22 46 C26 50 32 50 36 46"/>
          <path d="M46 36 C50 32 50 26 46 22 L42 18 C38 14 32 14 28 18"/>
          <line x1="26" y1="38" x2="38" y2="26"/>
        </g>
      </svg>
    </div>

    <!-- Title -->
    <h1 class="text-4xl md:text-6xl font-bold mb-6 animate-fade-in-up animate-delay-100">
      <span class="gradient-text">{t.hero.title}</span>
    </h1>

    <!-- Typing Animation -->
    <div class="h-8 mb-10 animate-fade-in-up animate-delay-200">
      <p id="typingText" class="text-lg md:text-xl text-text-secondary typing-text"></p>
    </div>

    <!-- CTA Buttons -->
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4 animate-fade-in-up animate-delay-300">
      <a href="#install" class="btn-primary">
        <ion-icon name="download-outline"></ion-icon>
        {t.hero.installBtn}
      </a>
      <a href="https://github.com/hxd-labs/locado#readme" target="_blank" rel="noopener noreferrer" class="btn-secondary">
        <ion-icon name="book-outline"></ion-icon>
        {t.hero.docsBtn}
      </a>
    </div>

    <!-- Scroll indicator -->
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce">
      <ion-icon name="chevron-down-outline" class="text-2xl text-text-secondary"></ion-icon>
    </div>
  </div>
</section>

<script define:vars={{ typingTexts: t.hero.typingTexts }}>
  const texts = typingTexts;
  const el = document.getElementById('typingText');
  let textIndex = 0;
  let charIndex = 0;
  let isDeleting = false;

  function type() {
    if (!el) return;

    const currentText = texts[textIndex];

    if (isDeleting) {
      el.textContent = currentText.substring(0, charIndex - 1);
      charIndex--;
    } else {
      el.textContent = currentText.substring(0, charIndex + 1);
      charIndex++;
    }

    let delay = isDeleting ? 30 : 50;

    if (!isDeleting && charIndex === currentText.length) {
      delay = 2000;
      isDeleting = true;
    } else if (isDeleting && charIndex === 0) {
      isDeleting = false;
      textIndex = (textIndex + 1) % texts.length;
      delay = 500;
    }

    setTimeout(type, delay);
  }

  type();
</script>
